{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.wixsite.com https://editor.wix.com https://www.craftahub.com https://craftahub.com;"
        }
      ]
    }
  ]
}
